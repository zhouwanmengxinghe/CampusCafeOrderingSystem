@model Microsoft.AspNetCore.Identity.IdentityUser
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "用户详情";
}

<h2 class="mb-4">用户详情</h2>

<div class="card mb-4">
    <div class="card-header">
        基本信息
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">用户ID</dt>
            <dd class="col-sm-9">@Model.Id</dd>

            <dt class="col-sm-3">邮箱</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">用户名</dt>
            <dd class="col-sm-9">@Model.UserName</dd>

            <dt class="col-sm-3">邮箱是否确认</dt>
            <dd class="col-sm-9">@((Model.EmailConfirmed) ? "是" : "否")</dd>
        </dl>
    </div>
</div>

<!-- 预留编辑按钮，暂时禁用 -->
<button class="btn btn-primary" disabled>编辑用户信息（预留）</button>
<a href="@Url.Action("ManageUsers", "Admin")" class="btn btn-secondary ms-2">返回用户列表</a>
